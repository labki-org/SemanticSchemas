{
	"name": "SemanticSchemas",
	"version": "0.1.0",
	"author": [
		"Daniel Aharoni"
	],
	"url": "https://www.mediawiki.org/wiki/Extension:SemanticSchemas",
	"descriptionmsg": "semanticschemas-desc",
	"license-name": "GPL-3.0-or-later",
	"type": "semantic",
	"requires": {
		"MediaWiki": ">= 1.43.0",
		"extensions": {
			"SemanticMediaWiki": "*",
			"PageForms": "*",
			"ParserFunctions": "*"
		}
	},
	"load_composer_autoloader": false,
	"ServiceWiringFiles": [
		"src/ServiceWiring.php"
	],
	"MessagesDirs": {
		"SemanticSchemas": [
			"i18n"
		]
	},
	"ExtensionMessagesFiles": {
		"SemanticSchemasAlias": "SemanticSchemas.alias.php"
	},
	"HookHandlers": {
		"CategoryPageHooks": {
			"class": "MediaWiki\\Extension\\SemanticSchemas\\Hooks\\CategoryPageHooks",
			"services": [
				"SemanticSchemas.WikiCategoryStore"
			]
		},
		"SetupHooks": {
			"class": "MediaWiki\\Extension\\SemanticSchemas\\Hooks\\SemanticSchemasSetupHooks"
		},
		"ParserHooks": {
			"class": "MediaWiki\\Extension\\SemanticSchemas\\Parser\\DisplayParserFunctions"
		}
	},
	"Hooks": {
		"SetupAfterCache": "SetupHooks",
		"ParserFirstCallInit": "ParserHooks",
		"SkinTemplateNavigation::Universal": "CategoryPageHooks",
		"ArticleViewFooter": "CategoryPageHooks"
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\SemanticSchemas\\": "src/"
	},
	"ResourceModules": {
		"ext.semanticschemas.styles": {
			"styles": [
				"resources/ext.semanticschemas.styles.css"
			],
			"localBasePath": "",
			"remoteExtPath": "SemanticSchemas",
			"targets": [
				"desktop",
				"mobile"
			]
		},
		"ext.semanticschemas.hierarchy": {
			"scripts": [
				"resources/ext.semanticschemas.hierarchy.js"
			],
			"styles": [
				"resources/ext.semanticschemas.hierarchy.css"
			],
			"dependencies": [
				"mediawiki.api",
				"mediawiki.util",
				"jquery"
			],
			"messages": [
				"semanticschemas-hierarchy-no-data",
				"semanticschemas-hierarchy-no-properties",
				"semanticschemas-hierarchy-loading",
				"semanticschemas-hierarchy-error",
				"semanticschemas-hierarchy-no-category",
				"semanticschemas-hierarchy-tree-title",
				"semanticschemas-hierarchy-props-title",
				"semanticschemas-hierarchy-source-category",
				"semanticschemas-hierarchy-properties",
				"semanticschemas-hierarchy-required-state",
				"semanticschemas-hierarchy-unknown-category",
				"semanticschemas-hierarchy-unnamed-property",
				"semanticschemas-hierarchy-required",
				"semanticschemas-hierarchy-optional"
			],
			"localBasePath": "",
			"remoteExtPath": "SemanticSchemas",
			"targets": [
				"desktop",
				"mobile"
			]
		},
		"ext.semanticschemas.createpage": {
			"scripts": [
				"resources/ext.semanticschemas.createpage.js"
			],
			"localBasePath": "",
			"remoteExtPath": "SemanticSchemas",
			"targets": [
				"desktop",
				"mobile"
			]
		},
		"ext.semanticschemas.hierarchy.formpreview": {
			"scripts": [
				"resources/ext.semanticschemas.hierarchy.formpreview.js"
			],
			"styles": [
				"resources/ext.semanticschemas.hierarchy.formpreview.css"
			],
			"dependencies": [
				"mediawiki.api",
				"jquery"
			],
			"localBasePath": "",
			"remoteExtPath": "SemanticSchemas",
			"targets": [
				"desktop",
				"mobile"
			]
		}
	},
	"APIModules": {
		"semanticschemas-hierarchy": {
			"class": "MediaWiki\\Extension\\SemanticSchemas\\Api\\ApiSemanticSchemasHierarchy",
			"services": [
				"SemanticSchemas.CategoryHierarchyService"
			]
		}
	},
	"SpecialPages": {
		"CreateSemanticPage": {
			"class": "MediaWiki\\Extension\\SemanticSchemas\\Special\\SpecialCreateSemanticPage",
			"services": [
				"SemanticSchemas.WikiCategoryStore",
				"SemanticSchemas.PageCreator",
				"NamespaceInfo",
				"WikiPageFactory"
			]
		},
		"SemanticSchemas": {
			"class": "MediaWiki\\Extension\\SemanticSchemas\\Special\\SpecialSemanticSchemas",
			"services": [
				"SemanticSchemas.WikiCategoryStore",
				"SemanticSchemas.WikiPropertyStore",
				"SemanticSchemas.TemplateGenerator",
				"SemanticSchemas.FormGenerator",
				"SemanticSchemas.DisplayStubGenerator",
				"SemanticSchemas.OntologyInspector",
				"SemanticSchemas.StateManager",
				"SemanticSchemas.PageHashComputer",
				"ObjectCacheFactory"
			]
		}
	},
	"LogTypes": [
		"semanticschemas"
	],
	"LogNames": {
		"semanticschemas": "semanticschemas-log-name"
	},
	"LogHeaders": {
		"semanticschemas": "semanticschemas-log-header"
	},
	"LogActionsHandlers": {
		"semanticschemas/generate": "LogFormatter"
	},
	"config": {
		"SemanticSchemasRequireApiAuth": {
			"value": false,
			"description": "If true, require 'read' permission to access the hierarchy API"
		},
		"SemanticSchemasRateLimitPerHour": {
			"value": 20,
			"description": "Maximum number of generate operations allowed per hour per user"
		}
	},
	"manifest_version": 2
}